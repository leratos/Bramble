#!/bin/sh
set -eu

if [ "${BRAMBLE_SKIP_GUARDRAILS:-}" = "1" ]; then
    exit 0
fi

msg_file="$1"
has_journal=0

while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
        "Journal: bramble#"[0-9]*)
            has_journal=1
            ;;
        "Journal: skipped ("*")")
            has_journal=1
            ;;
    esac
done < "$msg_file"

if [ "$has_journal" -eq 1 ]; then
    exit 0
fi

printf '%s\n' \
    "commit-msg: missing Bramble journal footer." \
    "" \
    "Add one of these lines to the commit message:" \
    "  Journal: bramble#123" \
    "  Journal: skipped (short reason)" \
    "" \
    "Use \"skipped\" only for trivial commits or when Bramble MCP is unavailable." >&2
exit 1
